# Discord Bot Token (Get this from Discord Developer Portal -> Bot -> Token)
DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE

# Application Client ID (Get this from Discord Developer Portal -> General Information -> Application ID)
CLIENT_ID=YOUR_APPLICATION_CLIENT_ID_HERE

# Supabase Project URL (Get this from Supabase Project Settings -> API)
SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL_HERE

# Supabase Project Anon/Public Key (Get this from Supabase Project Settings -> API)
SUPABASE_KEY=YOUR_SUPABASE_ANON_KEY_HERE
